# Database (Railway Postgres addon injects this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# S3 / MinIO
S3_ENDPOINT_URL=https://your-minio-endpoint.up.railway.app
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name

# MCP server (for Claude.ai Connector access)
# Generate a long random token (e.g. `openssl rand -hex 32`) and paste into Claude.ai
MCP_BEARER_TOKEN=
# GitHub Personal Access Token with `repo:read` scope, for reading source code
GH_TOKEN=
# Default branches that read_backend_file / read_frontend_file point at when
# the caller doesn't pass an explicit `ref` (can override per-call).
MCP_BACKEND_REF=feature/fire-config
MCP_FRONTEND_REF=main
